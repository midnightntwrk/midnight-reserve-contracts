{
  "name": "offchain",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf ./dist",
    "check": "tsc --noEmit",
    "lint": "eslint 'cli-yargs/**/*.ts' 'tests/**/*.ts' --ignore-pattern '**/dist/**'",
    "lint:fix": "bun lint --fix",
    "fmt": "prettier --write 'cli-yargs/**/*.ts' 'tests/**/*.ts'",
    "fmt:check": "prettier --check 'cli-yargs/**/*.ts' 'tests/**/*.ts'",
    "cli": "bun run cli-yargs/index.ts",
    "cli:deploy": "bun run cli-yargs/index.ts deploy",
    "cli:deploy:local": "bun run cli-yargs/index.ts deploy -n local",
    "cli:deploy:preview": "bun run cli-yargs/index.ts deploy -n preview",
    "cli:deploy:preprod": "bun run cli-yargs/index.ts deploy -n preprod",
    "cli:info": "bun run cli-yargs/index.ts info",
    "cli:info:preview": "bun run cli-yargs/index.ts info -n preview",
    "cli:simple-tx": "bun run cli-yargs/index.ts simple-tx"
  },
  "devDependencies": {
    "@blaze-cardano/blueprint": "^0.8.2",
    "@blaze-cardano/data": "^0.6.6",
    "@blaze-cardano/emulator": "^0.4.4",
    "@blaze-cardano/query": "^0.5.6",
    "@blaze-cardano/sdk": "^0.2.47",
    "@blaze-cardano/uplc": "^0.4.3",
    "@blaze-cardano/vm": "^0.2.3",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "cbor": "^10.0.11",
    "eslint": "^9.37.0",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@types/yargs": "^17.0.35",
    "toml": "^3.0.0",
    "yargs": "^18.0.0"
  }
}
