{
  "name": "aiken-demo-backend",
  "version": "0.1.0",
  "description": "Backend server for testing and demoing Aiken smart contracts",
  "main": "dist/index.js",
  "bin": {
    "blaze-server": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "API_DOCUMENTATION.md"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "npm run clean && npm run compile && npm run copy-assets",
    "clean": "rm -rf dist",
    "compile": "tsc",
    "copy-assets": "cp -r src/demo-interpreter/monadic dist/demo-interpreter/ && cp -r src/demo-interpreter/core/*.js dist/demo-interpreter/core/",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "test:phase0": "bun test src/tests/phase0",
    "test:phase1": "bun test src/tests/phase1",
    "test:phase2": "bun test src/tests/phase2",
    "test:phase4": "bun test src/tests/phase4",
    "test": "bun test src/tests",
    "test:exploration": "bun test ./exploration/tests/*.exploration.ts ./exploration/unfakeable-transaction-ids/tests/phase3/*.exploration.ts",
    "demo": "bun src/demo-interpreter/cli/demo-runner.ts",
    "demo:run": "node src/demo-interpreter/monadic/test-runner.js",
    "demo:serve": "bunx http-server -p 8080 -c-1",
    "demo:server": "node src/demo-interpreter/server/demo-server.js",
    "demo:web": "bunx http-server -p 8080 -c-1 -o",
    "demo:start": "npm run build && node scripts/start-demo-servers.js",
    "pack": "npm run build && npm pack",
    "publish:npm": "npm run build && npm publish"
  },
  "keywords": [
    "cardano",
    "aiken",
    "blaze",
    "emulator"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@babel/generator": "^7.28.3",
    "@babel/parser": "^7.28.3",
    "@babel/traverse": "^7.28.3",
    "@babel/types": "^7.28.2",
    "@blaze-cardano/emulator": "^0.3.29",
    "@blaze-cardano/sdk": "^0.2.33",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "pegjs": "^0.10.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
