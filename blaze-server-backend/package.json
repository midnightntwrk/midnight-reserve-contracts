{
  "name": "aiken-demo-backend",
  "version": "0.1.0",
  "description": "Backend server for testing and demoing Aiken smart contracts",
  "main": "dist/server.js",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "test:phase0": "bun test src/tests/phase0",
    "test:phase1": "bun test src/tests/phase1",
    "test:phase2": "bun test src/tests/phase2",
    "test:phase4": "bun test src/tests/phase4",
    "test": "bun test src/tests",
    "test:exploration": "bun test ./exploration/tests/*.exploration.ts ./exploration/unfakeable-transaction-ids/tests/phase3/*.exploration.ts"
  },
  "keywords": ["cardano", "aiken", "blaze", "emulator"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@blaze-cardano/sdk": "^0.2.33",
    "@blaze-cardano/emulator": "^0.3.29",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0"
  }
}
