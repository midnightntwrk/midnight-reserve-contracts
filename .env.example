# Blockfrost API Keys
# Get your API keys from https://blockfrost.io

# Preview testnet API key
BLOCKFROST_PREVIEW_API_KEY=preview_api_key_here

# Preprod testnet API key
BLOCKFROST_PREPROD_API_KEY=preprod_api_key_here

# Mainnet API key
BLOCKFROST_MAINNET_API_KEY=mainnet_api_key_here

# Deployer Address
# This is the address that will deploy the contracts and provide UTxOs
# For mainnet, this MUST be set to your actual address
# For testnets, this is optional (will use default testnet address if not set)

# Example testnet address (replace with your own)
DEPLOYER_ADDRESS=addr_test1qpw0djgj0x59ngrjvqthn7enhvruxnsavsw5th63la3mjel3tkc974sr23jmlzgq5zda4gtv8k9cy38756r9y3qgmkqqjz6aa7

# Example mainnet address (replace with your own)
# DEPLOYER_ADDRESS=addr1qx2fxv2umyhttkxyxp8x0dlpdt3k6cwng5pxj3jhsydzer3jcu5d8ps7zex2k2xt3uqxgjqnnj83ws8lhrn648jjxtwq2ytjmg

# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace the placeholder values with your actual API keys and address
# 3. Source the environment: source .env (or use direnv if you have .envrc)
