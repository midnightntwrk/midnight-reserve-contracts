# Maestro Key (Optional)
MAESTRO_PREVIEW_API_KEY=API_KEY
MAESTRO_PREVIEW_URL=URL_HERE
# Blockfrost API Keys
# Get your API keys from https://blockfrost.io

# Preview testnet API key
BLOCKFROST_PREVIEW_API_KEY=preview_api_key_here

# Preprod testnet API key
BLOCKFROST_PREPROD_API_KEY=preprod_api_key_here

# Mainnet API key
BLOCKFROST_MAINNET_API_KEY=mainnet_api_key_here

# Deployer Address
# This is the address that will deploy the contracts and provide UTxOs
# For mainnet, this MUST be set to your actual address
# For testnets, this is optional (will use default testnet address if not set)

# Example testnet address (replace with your own)
DEPLOYER_ADDRESS=addr_test1qpw0djgj0x59ngrjvqthn7enhvruxnsavsw5th63la3mjel3tkc974sr23jmlzgq5zda4gtv8k9cy38756r9y3qgmkqqjz6aa7

# Example mainnet address (replace with your own)
# DEPLOYER_ADDRESS=addr1qx2fxv2umyhttkxyxp8x0dlpdt3k6cwng5pxj3jhsydzer3jcu5d8ps7zex2k2xt3uqxgjqnnj83ws8lhrn648jjxtwq2ytjmg

TECH_AUTH_SIGNERS="
key1:ssrkey1,
key2:ssrkey2,
key3:ssrkey3,
"

COUNCIL_SIGNERS="
key1:ssrkey1,
key2:ssrkey2,
key3:ssrkey3,
"

TECH_AUTH_PRIVATE_KEYS=sk1,sk2,sk3


COUNCIL_PRIVATE_KEYS=sk1,sk2,sk3

# Permissioned candidates for FederatedOps appendix
# Format: sidechain_pub_key matches partner_chains_key field
# aura/grandpa/beefy are candidate keys with 4-char identifiers (aura, gran, beef)
# Uncomment and modify one of the environment-specific sections below
PERMISSIONED_CANDIDATES="[
  {
    sidechain_pub_key:020a617391de0e0291310bf7792bb41d9573e8a054b686205da5553e08fac6d0b8,
    aura_pub_key:1254f7017f0b8347ce7ab14f96d818802e7e9e0c0d1b7c9acb3c726b080e7a03,
    grandpa_pub_key:5079bcd20fd97d7d2f752c4607012600b401950260a91821f73e692071c82bf5,
    beefy_pub_key:020a617391de0e0291310bf7792bb41d9573e8a054b686205da5553e08fac6d0b8
  }
]"

# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace the placeholder values with your actual API keys and address
# 3. Source the environment: source .env (or use direnv if you have .envrc)
